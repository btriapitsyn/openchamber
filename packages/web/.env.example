# OpenChamber Web Server Configuration
# Copy to .env and fill in your values

# ── OpenCode Connection ──
# OPENCODE_HOST=http://localhost:4095
# OPENCODE_SKIP_START=true

# ── Server ──
# OPENCHAMBER_HOST=0.0.0.0
# OPENCHAMBER_DIST_DIR=
# OPENCHAMBER_RUNTIME=web

# ── Authentication ──
# OPENCHAMBER_UI_PASSWORD=
# OPENCODE_JWT_SECRET=

# ── GitHub ──
# OPENCHAMBER_GITHUB_CLIENT_ID=
# OPENCHAMBER_GITHUB_SCOPES=

# ── TWA (Trusted Web Activity) ──
# TWA_SHA256_FINGERPRINT=
# TWA_PACKAGE_NAME=

# ── Rate Limiting ──
# OPENCHAMBER_RATE_LIMIT_MAX_ATTEMPTS=10
# OPENCHAMBER_RATE_LIMIT_NO_IP_MAX_ATTEMPTS=3

# ── Push Notifications ──
# OPENCHAMBER_VAPID_SUBJECT=
# OPENCHAMBER_PUBLIC_ORIGIN=

# ── Data & Paths ──
# OPENCHAMBER_DATA_DIR=

# ── Feature Flags ──
# OPENCHAMBER_DESKTOP_NOTIFY=false

# ── Binaries (auto-detected; override if needed) ──
# OPENCHAMBER_OPENCODE_BIN=
# OPENCHAMBER_OPENCODE_PATH=
# OPENCHAMBER_GIT_BINARY=
# OPENCHAMBER_NODE_BINARY=
# OPENCHAMBER_BUN_BINARY=
